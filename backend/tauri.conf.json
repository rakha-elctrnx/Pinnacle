{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Pinnacle",
  "version": "0.1.0",
  "identifier": "com.pinnacle.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Pinnacle",
        "label": "main",
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": {
          "x": 19,
          "y": 22
        },
        "width": 1360,
        "height": 860,
        "minWidth": 1080,
        "minHeight": 680,
        "resizable": true,
        "fullscreen": false
      },
      {
        "label": "new-connection",
        "title": "New Connection",
        "url": "/new-connection",
        "hiddenTitle": true,
        "titleBarStyle": "Overlay",
        "trafficLightPosition": {
          "x": 14,
          "y": 14
        },
        "width": 520,
        "height": 680,
        "minWidth": 520,
        "minHeight": 680,
        "resizable": true,
        "visible": false,
        "center": true,
        "decorations": true,
        "alwaysOnTop": true,
        "focus": true,
        "minimizable": false,
        "fullscreen": false,
        "parent": "main"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}